# ─── Database ───
DATABASE_URL="file:./dev.db"

# ─── Auth ───
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_to_a_random_64char_hex_string"

# ─── Email (SMTP) ───
# Option 1: Gmail (easiest)
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create an app password for "Mail" → copy the 16-char password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM="MoodTunes <your-email@gmail.com>"

# Option 2: Resend (modern, recommended for production)
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="resend"
# SMTP_PASS="re_your_api_key"
# SMTP_FROM="MoodTunes <noreply@your-domain.com>"

# Option 3: Outlook/Hotmail
# SMTP_HOST="smtp-mail.outlook.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-email@outlook.com"
# SMTP_PASS="your-password"
# SMTP_FROM="your-email@outlook.com"
